# ─────────────────────────────────────────────────────────────
# Environment variables
#
# HOW TO USE:
#   1. Copy this file and rename it to .env
#   2. Fill in your actual Render backend URL
#   3. Never commit .env to GitHub (it's in .gitignore)
#
# On Render (when deploying the frontend):
#   Add this variable in Render → your site → Environment
# ─────────────────────────────────────────────────────────────

REACT_APP_API_URL=http://localhost:8000


